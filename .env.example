# RaidenShogun Music Bot — environment template
# Copy this file to `.env` and fill in real values. `.env` itself is
# gitignored and must NEVER be committed.

# ─── Required ────────────────────────────────────────────────────────────
# Get API_ID + API_HASH from https://my.telegram.org → API development tools
API_ID=
API_HASH=

# BOT_TOKEN from @BotFather
BOT_TOKEN=

# STRING_SESSION for the assistant userbot. Generate with:
#   python3 scripts/session_gen.py
# WARNING: a leaked STRING_SESSION grants FULL ACCESS to that Telegram
# account — not just bot scope. Treat it like a password.
STRING_SESSION=

# Deployer's Telegram user id. Comma/whitespace list accepted.
# Use SUDO_USERS for additional delegated sudoers without owner powers.
OWNER_ID=

# ─── Optional ────────────────────────────────────────────────────────────
# Path to a Netscape-format cookies.txt exported from a logged-in
# YouTube browser session. Without this, YouTube's bot-check wall will
# block most extractions from datacenter IPs.
COOKIES_FILE=

# Same idea for Instagram links via /play or /song.
INSTAGRAM_COOKIES_FILE=

# External media-downloader microservice. When MEDIA_API_URL is set,
# Instagram and Pinterest downloads call it first; the local yt-dlp path
# is the fallback for transient failures only.
MEDIA_API_URL=
MEDIA_API_KEY=

# Per-platform kill switch for the media API. Set to false when the API
# host can't reach Instagram (datacenter IP repeatedly returning
# login_required) — the IG handler will skip the API and go straight to
# the local fallback. Pinterest is unaffected by this flag.
# Default: true.
MEDIA_API_INSTAGRAM_ENABLED=true

# Outbound proxies (any of these can be set independently):
#   PROXY_URL      — single proxy for Telegram + yt-dlp
#   YT_DLP_PROXY   — yt-dlp-specific override
PROXY_URL=
YT_DLP_PROXY=

# Spotify lookups (client-credentials flow).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Persistence paths. Defaults shown.
# CHATS_FILE=chats.json
# GREETINGS_FILE=greetings.json
# DEPARTURE_OFF_FILE=departure_off.json

# Comma/whitespace-separated list of additional sudo users.
SUDO_USERS=
